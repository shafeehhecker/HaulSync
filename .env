# ===========================
# HaulSync Environment Config
# ===========================

# --- Database ---
POSTGRES_DB=haulsync
POSTGRES_USER=haulsync
POSTGRES_PASSWORD=change_this_strong_password

# --- Backend ---
DATABASE_URL=postgresql://haulsync:change_this_strong_password@postgres:5432/haulsync
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d
NODE_ENV=production

# --- Frontend ---
VITE_API_URL=http://localhost:5000

# --- URLs ---
FRONTEND_URL=http://localhost:3000
