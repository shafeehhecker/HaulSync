// HaulSync — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// USER & AUTH
// ========================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
  TRANSPORTER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(OPERATOR)
  phone     String?
  isActive  Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfqsCreated      RFQ[]         @relation("CreatedBy")
  shipmentsCreated Shipment[]    @relation("CreatedBy")
  quotes           Quote[]
  activityLogs     ActivityLog[]

  @@map("users")
}

// ========================
// MASTERS
// ========================

enum CompanyType {
  SHIPPER
  TRANSPORTER
  BROKER
  CONSIGNEE
  BOTH
}

model Company {
  id            String      @id @default(uuid())
  name          String
  type          CompanyType
  gstin         String?
  pan           String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  email         String?
  contactPerson String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  users     User[]
  vehicles  Vehicle[]
  drivers   Driver[]
  rfqs      RFQ[]      @relation("ShipperCompany")
  quotes    Quote[]    @relation("TransporterCompany")
  shipments Shipment[] @relation("ShipperCompany")
  invoices  Invoice[]

  @@map("companies")
}

enum VehicleType {
  TRUCK
  TRAILER
  CONTAINER
  TANKER
  REFRIGERATED
  FLATBED
  MINI_TRUCK
  TEMPO
}

model Vehicle {
  id              String      @id @default(uuid())
  registrationNo  String      @unique
  type            VehicleType
  capacity        Float // in tonnes
  bodyType        String?
  make            String?
  model           String?
  year            Int?
  insuranceExpiry DateTime?
  pucExpiry       DateTime?
  fitnessExpiry   DateTime?
  permitExpiry    DateTime?
  companyId       String?
  company         Company?    @relation(fields: [companyId], references: [id])
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  trips Shipment[]

  @@map("vehicles")
}

model Driver {
  id               String    @id @default(uuid())
  name             String
  phone            String    @unique
  licenseNo        String    @unique
  licenseExpiry    DateTime?
  address          String?
  city             String?
  state            String?
  emergencyContact String?
  rating           Float     @default(5.0)
  totalTrips       Int       @default(0)
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id])
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trips Shipment[]

  @@map("drivers")
}

model GoodsType {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  isHazardous  Boolean  @default(false)
  isPerishable Boolean  @default(false)
  createdAt    DateTime @default(now())

  rfqs      RFQ[]
  shipments Shipment[]

  @@map("goods_types")
}

model Route {
  id            String   @id @default(uuid())
  name          String
  originCity    String
  originState   String
  destCity      String
  destState     String
  distanceKm    Float?
  estimatedDays Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rfqs      RFQ[]
  shipments Shipment[]

  @@map("routes")
}

// ========================
// RFQ & INDENTING
// ========================

enum RFQStatus {
  DRAFT
  OPEN
  QUOTED
  AWARDED
  CANCELLED
  EXPIRED
}

model RFQ {
  id               String      @id @default(uuid())
  rfqNumber        String      @unique
  title            String
  shipperCompanyId String
  shipper          Company     @relation("ShipperCompany", fields: [shipperCompanyId], references: [id])
  originCity       String
  originState      String
  destCity         String
  destState        String
  routeId          String?
  route            Route?      @relation(fields: [routeId], references: [id])
  goodsTypeId      String?
  goodsType        GoodsType?  @relation(fields: [goodsTypeId], references: [id])
  weight           Float?
  quantity         Int         @default(1)
  vehicleType      VehicleType
  loadingDate      DateTime
  deliveryDate     DateTime?
  description      String?
  basePrice        Float?
  status           RFQStatus   @default(OPEN)
  createdById      String
  createdBy        User        @relation("CreatedBy", fields: [createdById], references: [id])
  expiresAt        DateTime?
  awardedQuoteId   String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  quotes       Quote[]
  awardedQuote Quote?  @relation("AwardedQuote", fields: [awardedQuoteId], references: [id])

  @@map("rfqs")
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

model Quote {
  id            String      @id @default(uuid())
  rfqId         String
  rfq           RFQ         @relation(fields: [rfqId], references: [id])
  transporterId String
  transporter   Company     @relation("TransporterCompany", fields: [transporterId], references: [id])
  submittedById String
  submittedBy   User        @relation(fields: [submittedById], references: [id])
  amount        Float
  currency      String      @default("INR")
  validUntil    DateTime?
  notes         String?
  status        QuoteStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  awardedFor RFQ?      @relation("AwardedQuote")
  shipment   Shipment?

  @@map("quotes")
}

// ========================
// SHIPMENTS & TRACKING
// ========================

enum ShipmentStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  REACHED_DESTINATION
  DELIVERED
  POD_UPLOADED
  COMPLETED
  CANCELLED
}

model Shipment {
  id               String         @id @default(uuid())
  shipmentNumber   String         @unique
  shipperCompanyId String
  shipper          Company        @relation("ShipperCompany", fields: [shipperCompanyId], references: [id])
  quoteId          String?        @unique
  quote            Quote?         @relation(fields: [quoteId], references: [id])
  routeId          String?
  route            Route?         @relation(fields: [routeId], references: [id])
  vehicleId        String?
  vehicle          Vehicle?       @relation(fields: [vehicleId], references: [id])
  driverId         String?
  driver           Driver?        @relation(fields: [driverId], references: [id])
  goodsTypeId      String?
  goodsType        GoodsType?     @relation(fields: [goodsTypeId], references: [id])
  originCity       String
  originState      String
  destCity         String
  destState        String
  weight           Float?
  quantity         Int            @default(1)
  freightAmount    Float?
  loadingDate      DateTime
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  status           ShipmentStatus @default(PENDING)
  ewayBillNo       String?
  ewayBillExpiry   DateTime?
  lrNumber         String?
  notes            String?
  createdById      String
  createdBy        User           @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  trackingEvents TrackingEvent[]
  pods           POD[]
  invoice        Invoice?

  @@map("shipments")
}

model TrackingEvent {
  id         String   @id @default(uuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  eventType  String // DEPARTED, REACHED_CHECKPOINT, HALTED, DELIVERED, etc.
  location   String
  city       String?
  state      String?
  latitude   Float?
  longitude  Float?
  notes      String?
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@map("tracking_events")
}

model POD {
  id         String    @id @default(uuid())
  shipmentId String
  shipment   Shipment  @relation(fields: [shipmentId], references: [id])
  imageUrl   String
  signedBy   String?
  receivedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())

  @@map("pods")
}

// ========================
// INVOICES
// ========================

enum InvoiceStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DISPUTED
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  shipmentId    String        @unique
  shipment      Shipment      @relation(fields: [shipmentId], references: [id])
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  freightAmount Float
  gstAmount     Float         @default(0)
  totalAmount   Float
  currency      String        @default("INR")
  status        InvoiceStatus @default(PENDING)
  invoiceDate   DateTime
  dueDate       DateTime?
  paidDate      DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("invoices")
}

// ========================
// ACTIVITY LOG
// ========================

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}
